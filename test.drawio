2, 192); box-shadow: none !important;&quot;&gt;&lt;font color=&quot;rgba(0, 0, 0, 0)&quot; size=&quot;3&quot; style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;&lt;span style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); white-space-collapse: preserve; color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;- Drone speed &lt;/span&gt;&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; text-align: left; color: rgb(192, 192, 192); background-color: rgb(27, 29, 30); box-shadow: none !important;&quot;&gt;&lt;b style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;&lt;font color=&quot;rgba(0, 0, 0, 0)&quot; size=&quot;3&quot; style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;&lt;span style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); white-space-collapse: preserve; color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;&lt;span style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); white-space: pre; color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;-&lt;u style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt; recommended 10 m/s&lt;/u&gt; as all test with drone speed 10 m/s &lt;br style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;&lt;/span&gt;&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; text-align: left; color: rgb(192, 192, 192); background-color: rgb(27, 29, 30); box-shadow: none !important;&quot;&gt;&lt;b style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;&lt;font color=&quot;rgba(0, 0, 0, 0)&quot; size=&quot;3&quot; style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;&lt;span style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); white-space-collapse: preserve; color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;- Updated home &lt;/span&gt;&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; text-align: left; color: rgb(192, 192, 192); background-color: rgb(27, 29, 30); box-shadow: none !important;&quot;&gt;&lt;b style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;&lt;font color=&quot;rgba(0, 0, 0, 0)&quot; size=&quot;3&quot; style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;&lt;span style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); white-space-collapse: preserve; color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;&lt;span style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); white-space: pre; color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;- due to use gps from remote to updated home position, average error is 3-4 meters. -&amp;gt; &lt;u style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;When updated home pilot will be stand at target point and waiting a few seconds(20-30 sec) before press updated home. When RTH drone will&lt;/u&gt;&lt;span style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt; &lt;/span&gt;&lt;/span&gt;&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); font-family: Helvetica; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; text-wrap-mode: nowrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; text-align: left; background-color: rgb(27, 29, 30); color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;&lt;font style=&quot;&quot; size=&quot;3&quot;&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;b style=&quot;&quot;&gt;&lt;font color=&quot;rgba(0, 0, 0, 0)&quot;&gt;&amp;nbsp;   &lt;/font&gt;&lt;u style=&quot;&quot;&gt;&lt;font color=&quot;rgba(0, 0, 0, 0)&quot;&gt;decent and at altitude 15 m. pilot should press hold and press release winch payload manually. If drone not decent in target point, pilot will be manually take &lt;/font&gt;&lt;/u&gt;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); orphans: 2; text-indent: 0px; widows: 2; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; text-align: left; background-color: rgb(27, 29, 30); box-shadow: none !important; color: rgb(192, 192, 192);&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(192, 192, 192), rgb(72, 72, 72)); font-family: Helvetica; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; text-transform: none; word-spacing: 0px; -webkit-text-stroke-width: 0px; text-wrap-mode: nowrap;&quot; size=&quot;3&quot;&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;b style=&quot;&quot;&gt;&lt;font color=&quot;rgba(0, 0, 0, 0)&quot;&gt;    - when already release payload, pilot will be upload pre-plan mission to drone while it flying -&amp;gt; &lt;u&gt;concern pilot anxios&lt;/u&gt;&lt;/font&gt;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; white-space: pre;&quot;&gt;&lt;font size=&quot;3&quot; color=&quot;#ededed&quot;&gt;&lt;b&gt;&lt;u&gt;!!, prepare mission and cross check mission before start delivery mission. &lt;/u&gt;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; text-align: left; color: rgb(192, 192, 192); background-color: rgb(27, 29, 30); box-shadow: none !important;&quot;&gt;&lt;b style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;&lt;font color=&quot;rgba(0, 0, 0, 0)&quot; size=&quot;3&quot; style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;&lt;span style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); white-space-collapse: preserve; color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;&lt;span style=&quot;forced-color-adjust: none; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); white-space: pre; color: rgb(192, 192, 192); box-shadow: none !important;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;strokeColor=none;" parent="1" vertex="1">
